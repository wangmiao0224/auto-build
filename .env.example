# GitLab 配置
NUXT_GITLAB_URL=https://gitlab.com
NUXT_GITLAB_TOKEN=your_personal_access_token

# AI 助手配置（可选）
NUXT_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
NUXT_OPENAI_BASE_URL=https://api.openai.com/v1
NUXT_OPENAI_MODEL=gpt-4o-mini

# 数据加密密钥（生产环境请修改为随机字符串）
NUXT_ENCRYPT_KEY=fastbuild-default-key-change-me!
